# Copy to .env and fill in. .env is gitignored.
#
# .env holds ONLY infrastructure: where each model is hosted. The model's
# behavior (name, prompt, categories, coord space) lives in its ModelSpec in
# labeling_t/models.py, not here. The framework is decoupled from hosting.
#
# Per-model vars are named {MODEL_ENV_PREFIX}_ENDPOINT / _API_KEY.

# --- LocateAnything-3B (spec: labeling_t/models.py:LOCATE_ANYTHING) ---
# Reachable from THIS machine: a public host:port, or a local port if you
# SSH-tunnel the GPU box (ssh -N -L 8000:localhost:8000 user@gpu-box).
LOCATE_ANYTHING_ENDPOINT=http://localhost:8000
# Only if you started vLLM with --api-key; leave blank otherwise.
LOCATE_ANYTHING_API_KEY=

# Future models add their own pair, e.g.:
# QWEN_VL_ENDPOINT=http://localhost:8001
# QWEN_VL_API_KEY=

# RunPod provisioning (scripts/runpod.py). Empty = use runpodctl stored login.
RUNPOD_API_KEY=

# Cloud storage (S3 / DigitalOcean Spaces) — for cloud frames + labels.
# Creds via standard AWS_* env (same as StreamScout).
S3_ENDPOINT_URL=https://fra1.digitaloceanspaces.com
S3_REGION=fra1
S3_BUCKET=ml-cv-data
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
