# Copy to .env and fill in. .env is gitignored.
#
# .env holds ONLY infrastructure: where each model is hosted. The model's
# behavior (name, prompt, categories, coord space) lives in its ModelSpec in
# labeling_t/models.py, not here. The framework is decoupled from hosting.
#
# Per-model vars are named {MODEL_ENV_PREFIX}_ENDPOINT / _API_KEY.
# NOTE: the *_ENDPOINT vars are DEPRECATED — `labeling-t-runpod up` records
# endpoints in .labeling-t/pods.json and inference commands resolve them
# automatically (--endpoint flag overrides). Set an endpoint here only for a
# host the framework didn't provision. Keys stay here; this file is secrets.

# --- LocateAnything-3B (spec: labeling_t/models.py:LOCATE_ANYTHING) ---
# Reachable from THIS machine: a public host:port, or a local port if you
# SSH-tunnel the GPU box (ssh -N -L 8000:localhost:8000 user@gpu-box).
LOCATE_ANYTHING_ENDPOINT=http://localhost:8000
# Only if you started vLLM with --api-key; leave blank otherwise.
LOCATE_ANYTHING_API_KEY=

# Future self-hosted models add their own pair, e.g.:
# QWEN_VL_ENDPOINT=http://localhost:8001
# QWEN_VL_API_KEY=

# --- Hosted API models: the endpoint is baked into the spec, so set ONLY the key.
# OpenAI (spec: labeling_t/models.py:OPENAI_VL).
OPENAI_API_KEY=
# Override the base only for Azure / a proxy:
# OPENAI_ENDPOINT=https://api.openai.com/v1

# Google Gemini via its OpenAI-compat endpoint (spec: labeling_t/models.py:GEMINI_VL).
GEMINI_API_KEY=
# GEMINI_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/openai

# RunPod provisioning (scripts/runpod.py). Empty = use runpodctl stored login.
RUNPOD_API_KEY=

# Cloud storage (S3 / DigitalOcean Spaces) — for cloud frames + labels.
# Creds via standard AWS_* env (same as StreamScout).
S3_ENDPOINT_URL=https://fra1.digitaloceanspaces.com
S3_REGION=fra1
S3_BUCKET=ml-cv-data
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Label Studio. Read by BOTH the web UI (`labeling-t-web`) AND the CLI cloud
# commands (import-ls-cloud / from-ls-cloud) — so --url / --api-key default to
# these and never need to be typed. LS_URL defaults to http://localhost:8080.
# The local docker-compose ships a fixed dev token (see docker-compose.yml).
LS_URL=http://localhost:8080
LS_API_KEY=0a1b2c3d4e5f60718293a4b5c6d7e8f901234567

# Only for the CORS quick-fix (scripts/ls_project_local_frames.py): the static
# host serving frames same-origin while the object store lacks CORS. Normally
# unset — frames load via presigned S3 URLs.
# LS_IMAGE_BASE_URL=https://<ls-host>/frames
