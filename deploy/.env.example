# Deploy config for the cloud Label Studio stack (deploy/docker-compose.yml).
# cloud-init writes this automatically; fill it in only for a manual setup.
LS_DOMAIN=161-35-197-123.nip.io        # <droplet-ip-with-dashes>.nip.io (auto-HTTPS, no DNS)
LS_HOST=https://161-35-197-123.nip.io  # must match LS_DOMAIN, https://
LS_USER=admin@labeling-t.local
LS_PASSWORD=change-me-strong
LS_TOKEN=replace-with-40-hex-chars     # openssl rand -hex 20
